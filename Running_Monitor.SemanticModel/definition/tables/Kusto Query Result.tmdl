	column CondicionRunning
		dataType: string
		lineageTag: 38881719-c624-48ac-bd92-02a407464f1f
		summarizeBy: none
		sourceColumn: CondicionRunning

		annotation SummarizationSetBy = Automatic

	partition 'Kusto Query Result' = m
		mode: directQuery
		source = ```
				let
				Source = AzureDataExplorer.Contents("https://trd-5x52gjsx3b3627ugmm.z0.kusto.fabric.microsoft.com", "1b17c5d2-adfd-48d6-811f-355a0a7bbac6", "tiempo_sfco_cba_ar
				| extend FechaHora = todatetime(dateTime)
				| where FechaHora >= startofday(now())
				// Esto elimina duplicados exactos basados en la fecha y hora
				| summarize arg_max(FechaHora, *) by FechaHora 
				| project 
				    UltimaActualizacion = FechaHora,
				    EstadoCielo = description,
				    Temperatura_C = todouble(temperature.value),
				    SensacionTermica_C = todouble(realFeelTemperature.value),
				    HumedadRelativa_Porc = toint(relativeHumidity),
				    Viento_kmh = todouble(wind.speed.value),
				    VientoDireccion = wind.direction.description,
				    RafagasViento_kmh = todouble(windGust.speed.value),
				    Visibilidad_km = todouble(visibility.value),
				    LluviaUltimaHora_mm = todouble(precipitationSummary.pastHour.value),
				    PuntoRocio_C = todouble(dewPoint.value)
				| extend 
				    CondicionRunning = case(
				        Viento_kmh > 40 or LluviaUltimaHora_mm > 5, ""⚠️ Peligroso"",
				        Temperatura_C > 32 or SensacionTermica_C < 5, ""⚠️ Extremo"",
				        ""✅ Buena para correr""
				    )
				| order by UltimaActualizacion desc
				", [])
				in
				Source
				```

	annotation PBI_ResultType = Table

